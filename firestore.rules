rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasFriendDoc(ownerUid, friendUid) {
      return exists(/databases/$(database)/documents/users/$(ownerUid)/friends/$(friendUid));
    }

    function acceptedRequestBy(requesterUid, recipientUid) {
      return exists(/databases/$(database)/documents/friendRequests/$(requesterUid + "_" + recipientUid)) &&
        get(/databases/$(database)/documents/friendRequests/$(requesterUid + "_" + recipientUid)).data.status == "accepted";
    }

    function acceptedFriendLink(userId, friendId) {
      return acceptedRequestBy(userId, friendId) ||
        acceptedRequestBy(friendId, userId);
    }

    function isFriend(userId, friendId) {
      return isSignedIn() && hasFriendDoc(userId, friendId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /tasks/{taskId} {
        // Routines are stored on task docs through recurrenceGroupId, so owner-only
        // task access protects normal tasks, future tasks, and rolling routines together.
        allow read, write: if isOwner(userId);
      }

      match /focusSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /widgetSummary/{summaryId} {
        allow read, write: if isOwner(userId);
      }

      match /feedback/{feedbackId} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) ||
          (isSignedIn() &&
            request.auth.uid == friendId &&
            acceptedFriendLink(userId, friendId));
        allow delete: if isOwner(userId);
      }
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /publicUsernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.username == username;
      allow update, delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /publicProgress/{userId} {
      allow read: if isOwner(userId) || isFriend(userId, request.auth.uid);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
          resource.data.recipientUid == request.auth.uid);

      allow create: if isSignedIn() &&
        requestId == request.auth.uid + "_" + request.resource.data.recipientUid &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.recipientUid is string &&
        request.resource.data.status == "pending";

      allow update: if isSignedIn() &&
        resource.data.recipientUid == request.auth.uid &&
        request.resource.data.requesterUid == resource.data.requesterUid &&
        request.resource.data.recipientUid == resource.data.recipientUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ["accepted", "declined"];

      allow delete: if isSignedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
          resource.data.recipientUid == request.auth.uid);
    }

    match /accountabilityNudges/{nudgeId} {
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.toUid is string &&
        (hasFriendDoc(request.auth.uid, request.resource.data.toUid) ||
          hasFriendDoc(request.resource.data.toUid, request.auth.uid));

      allow update: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid) &&
        request.resource.data.fromUid == resource.data.fromUid &&
        request.resource.data.toUid == resource.data.toUid;

      allow delete: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid);
    }

    match /friendChallenges/{challengeId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdByUid &&
        request.auth.uid in request.resource.data.participantUids &&
        request.resource.data.participantUids is list &&
        request.resource.data.participantUids.size() == 2;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.participantUids == resource.data.participantUids;

      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;
    }
  }
}

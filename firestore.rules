rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasFriendDoc(ownerUid, friendUid) {
      return exists(/databases/$(database)/documents/users/$(ownerUid)/friends/$(friendUid));
    }

    function acceptedRequestBy(requesterUid, recipientUid) {
      return exists(/databases/$(database)/documents/friendRequests/$(requesterUid + "_" + recipientUid)) &&
        get(/databases/$(database)/documents/friendRequests/$(requesterUid + "_" + recipientUid)).data.status == "accepted";
    }

    function acceptedFriendLink(userId, friendId) {
      return acceptedRequestBy(userId, friendId) ||
        acceptedRequestBy(friendId, userId);
    }

    function isFriend(userId, friendId) {
      return isSignedIn() && hasFriendDoc(userId, friendId);
    }

    function validShortString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function optionalString(field, maxSize) {
      return !(field in request.resource.data) ||
        request.resource.data[field] == null ||
        (request.resource.data[field] is string &&
          request.resource.data[field].size() <= maxSize);
    }

    function optionalBool(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field] is bool;
    }

    function optionalNumber(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field] is number;
    }

    function validDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validTaskDoc() {
      return validShortString(request.resource.data.title, 180) &&
        validDateKey(request.resource.data.date) &&
        validShortString(request.resource.data.time, 20) &&
        request.resource.data.priority in ["Low", "Medium", "High"] &&
        request.resource.data.status in ["pending", "completed", "skipped"] &&
        request.resource.data.completed is bool &&
        optionalString("notes", 4000) &&
        optionalString("originalTime", 20) &&
        optionalString("recurrenceGroupId", 120) &&
        optionalString("parentTaskTitle", 180) &&
        optionalString("completionProof", 4000) &&
        optionalString("offlineQueuedAt", 80) &&
        optionalString("calendarEventId", 240) &&
        optionalString("calendarId", 240) &&
        optionalBool("aiCreated") &&
        optionalBool("breakdownCreated") &&
        optionalBool("rollingRoutine") &&
        optionalBool("offlineQueued") &&
        optionalBool("completionProofRequired") &&
        optionalNumber("rescheduledCount") &&
        optionalNumber("focusSessionCount") &&
        optionalNumber("focusMinutes") &&
        optionalNumber("cleanFocusSessions") &&
        (!("recurrence" in request.resource.data) ||
          request.resource.data.recurrence in ["none", "daily", "weekdays", "weekly", "custom"]) &&
        (!("recurrenceDays" in request.resource.data) ||
          request.resource.data.recurrenceDays == null ||
          (request.resource.data.recurrenceDays is list &&
            request.resource.data.recurrenceDays.size() <= 7));
    }

    function validProfileDoc(userId) {
      return (!("uid" in request.resource.data) || request.resource.data.uid == userId) &&
        optionalString("email", 160) &&
        optionalString("username", 32) &&
        optionalString("displayName", 60) &&
        optionalString("activePetKey", 40) &&
        optionalString("petNickname", 60) &&
        optionalString("planningRules", 1200) &&
        optionalString("weeklyFocusGoal", 240) &&
        optionalString("aiMemory", 800) &&
        optionalBool("proPreviewEnabled") &&
        optionalBool("tutorialCompleted") &&
        optionalBool("enableSounds") &&
        optionalBool("enableHaptics") &&
        optionalBool("soundEnabled") &&
        optionalBool("hapticsEnabled") &&
        optionalBool("calmFocusMusicEnabled") &&
        optionalNumber("focusDurationMinutes");
    }

    function validAppErrorDoc() {
      return validShortString(request.resource.data.source, 120) &&
        validShortString(request.resource.data.message, 1000) &&
        optionalString("name", 120) &&
        optionalString("stack", 8000) &&
        optionalString("appVersion", 40);
    }

    function validPublicProfile(userId) {
      return request.resource.data.uid == userId &&
        optionalString("email", 160) &&
        optionalString("username", 32) &&
        optionalString("displayName", 60);
    }

    function validUsernameReservation(username) {
      return request.resource.data.uid == request.auth.uid &&
        request.resource.data.username == username &&
        username.matches('^[a-z0-9_]{3,20}$') &&
        optionalString("email", 160);
    }

    function validFeedbackDoc() {
      return request.resource.data.type in ["Bug", "Confusing", "Idea", "Praise"] &&
        validShortString(request.resource.data.message, 2000) &&
        optionalString("email", 160) &&
        optionalString("appVersion", 40) &&
        optionalString("theme", 40);
    }

    function validFocusSessionDoc() {
      return validShortString(request.resource.data.taskTitle, 180) &&
        request.resource.data.minutes is number &&
        request.resource.data.minutes > 0 &&
        request.resource.data.minutes <= 240 &&
        optionalString("taskId", 120) &&
        optionalBool("strictFocus") &&
        optionalNumber("distractionStrikes");
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validProfileDoc(userId);
      allow delete: if isOwner(userId);

      match /tasks/{taskId} {
        // Routines are stored on task docs through recurrenceGroupId, so owner-only
        // task access protects normal tasks, future tasks, and rolling routines together.
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validTaskDoc();
        allow delete: if isOwner(userId);
      }

      match /focusSessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validFocusSessionDoc();
        allow delete: if isOwner(userId);
      }

      match /widgetSummary/{summaryId} {
        allow read, write: if isOwner(userId);
      }

      match /feedback/{feedbackId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validFeedbackDoc();
        allow delete: if isOwner(userId);
      }

      match /appErrors/{errorId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validAppErrorDoc();
        allow update: if false;
      }

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) ||
          (isSignedIn() &&
            request.auth.uid == friendId &&
            acceptedFriendLink(userId, friendId));
        allow delete: if isOwner(userId);
      }
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && validPublicProfile(userId);
      allow delete: if isOwner(userId);
    }

    match /publicUsernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        validUsernameReservation(username);
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        validUsernameReservation(username);
      allow delete: if isSignedIn() &&
        resource.data.uid == request.auth.uid;
    }

    match /publicProgress/{userId} {
      allow read: if isOwner(userId) || isFriend(userId, request.auth.uid);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
          resource.data.recipientUid == request.auth.uid);

      allow create: if isSignedIn() &&
        requestId == request.auth.uid + "_" + request.resource.data.recipientUid &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.recipientUid is string &&
        request.resource.data.recipientUid != request.auth.uid &&
        request.resource.data.status == "pending" &&
        optionalString("requesterEmail", 160) &&
        optionalString("requesterUsername", 32) &&
        optionalString("requesterName", 60) &&
        optionalString("recipientEmail", 160) &&
        optionalString("recipientUsername", 32) &&
        optionalString("recipientName", 60);

      allow update: if isSignedIn() &&
        resource.data.recipientUid == request.auth.uid &&
        request.resource.data.requesterUid == resource.data.requesterUid &&
        request.resource.data.recipientUid == resource.data.recipientUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ["accepted", "declined"];

      allow delete: if isSignedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
          resource.data.recipientUid == request.auth.uid);
    }

    match /accountabilityNudges/{nudgeId} {
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.toUid is string &&
        (hasFriendDoc(request.auth.uid, request.resource.data.toUid) ||
          hasFriendDoc(request.resource.data.toUid, request.auth.uid));

      allow update: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid) &&
        request.resource.data.fromUid == resource.data.fromUid &&
        request.resource.data.toUid == resource.data.toUid;

      allow delete: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid);
    }

    match /friendChallenges/{challengeId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdByUid &&
        request.auth.uid in request.resource.data.participantUids &&
        request.resource.data.participantUids is list &&
        request.resource.data.participantUids.size() == 2;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.participantUids == resource.data.participantUids;

      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.participantUids;
    }
  }
}

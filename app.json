{
  "expo": {
    "name": "Daily Discipline",
    "slug": "daily-discipline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "dailydiscipline",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/app-icon.png",
      "bundleIdentifier": "com.haroonzaman.dailydiscipline"
    },
    "android": {
      "package": "com.haroonzaman.dailydiscipline",
      "adaptiveIcon": {
        "backgroundColor": "#030647",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#030647",
          "dark": {
            "backgroundColor": "#030647"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

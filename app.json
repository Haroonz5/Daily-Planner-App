{
  "expo": {
    "name": "Daily Discipline",
    "slug": "daily-discipline",
    "version": "1.0.0",
    "description": "An AI-powered discipline planner with task scheduling, focus sessions, companion rewards, and accountability tools.",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "dailydiscipline",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/app-icon.png",
      "bundleIdentifier": "com.haroonzaman.dailydiscipline",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.haroonzaman.dailydiscipline",
      "adaptiveIcon": {
        "backgroundColor": "#030647",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#030647",
          "dark": {
            "backgroundColor": "#030647"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Daily Discipline to export your planned tasks to your calendar.",
          "remindersPermission": "Allow Daily Discipline to connect tasks with device reminders."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b5691ad-e84c-4617-b987-9a33d146b356"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b5691ad-e84c-4617-b987-9a33d146b356"
    }
  }
}

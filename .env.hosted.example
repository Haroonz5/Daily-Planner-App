# Hosted backend production/tester values.
# Keep real secrets out of git. Put these in Render/EAS dashboards instead.

# Render / backend secrets
AI_PROVIDER=auto
GEMINI_API_KEY=replace_on_render
OPENAI_API_KEY=
ADMIN_DASHBOARD_TOKEN=replace_on_render
SECURITY_AUTH_MODE=firebase
APP_CHECK_MODE=optional
SECURITY_ALLOWED_ORIGINS=*

# EAS mobile app public value. This is the Go security gateway URL, not Gemini.
EXPO_PUBLIC_AI_API_URL=https://your-security-gateway.onrender.com
EXPO_PUBLIC_REQUIRE_SECURE_AI=true

# Local hosted checks
HOSTED_GATEWAY_URL=https://your-security-gateway.onrender.com
HOSTED_AI_URL=https://your-ai-backend.onrender.com

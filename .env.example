EXPO_PUBLIC_AI_API_URL=https://your-security-gateway.example.com

# The mobile app should call the Go security gateway, not the Python AI service directly.
# Production secrets like Gemini/OpenAI keys stay on the backend only.

# For tester builds, point this at the hosted Go security gateway.
# Keep Gemini/OpenAI keys on the backend only.
EXPO_PUBLIC_REQUIRE_SECURE_AI=true
